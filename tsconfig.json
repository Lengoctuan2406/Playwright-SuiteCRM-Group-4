{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "verbatimModuleSyntax": true,
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "outDir": "./dist",
    "rootDir": ".",
    "moduleDetection": "force",
    "noEmit": true
  },
  "include": ["playwright.config.ts", "tests/**/*.spec.ts", "tests/**/*.ts", "src/**/*.ts"],
  "exclude": ["node_modules"]
}